## Functions runtime secrets (deploy: firebase functions:secrets:set veya .env ile emülatör)
# Shopier — Panel + API bilgileri (https://www.shopier.com)
# SHOPIER_API_KEY=
# SHOPIER_API_SECRET=
# Çoklu site varsa paneldeki sıra (genelde "1")
# SHOPIER_WEBSITE_INDEX=1
# Webhook: HTTPS tam URL (örn. https://europe-west1-PROJECT.cloudfunctions.net/shopierWebhook)
# SHOPIER_CALLBACK_URL=
# Kullanıcıyı ödeme sonrası geri almak için site kökü (örn. https://siteniz.com)
# APP_PUBLIC_URL=

# PAPARA_API_KEY=
# PAPARA_API_SECRET=
# SMS_PROVIDER_API_KEY=

# (İsteğe bağlı) sunucu tarafı varsayılan; asıl seçim istemcide VITE_PAYMENT_PROVIDER
# PAYMENT_PROVIDER=mock

# =============================================================================
# E-posta Doğrulama (Email Verification) - Gmail SMTP Ayarları
# =============================================================================
# SMTP Sunucu Ayarları
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Gmail Kimlik Bilgileri
# SMTP_USER=ornek@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx  # 16 haneli Gmail Uygulama Şifresi (boşluksuz)

# Not: Gmail'de 2-Faktörlü Doğrulama aktif olmalı ve Uygulama Şifresi oluşturulmalı
# Uygulama Şifresi oluşturma: https://myaccount.google.com/apppasswords
# =============================================================================
